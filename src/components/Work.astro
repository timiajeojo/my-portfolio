---
import { portfolio } from "../data/portfolio";
---

<section
  id="work"
  class="container-custom py-24"
>

  <p class="section-title">
    Work
  </p>

  <h2
    class="mb-16 max-w-3xl text-4xl font-bold md:text-5xl"
  >
    Experience & Journey
  </h2>

  <div class="relative">

    <div
      class="absolute left-2 top-0 h-full w-px bg-zinc-800"
    ></div>

    <div class="space-y-14">

      {
        portfolio.work.map((job) => (
          <div class="relative pl-10">

            <div
              class="absolute left-0 top-2 h-4 w-4 rounded-full border-4 border-zinc-950 bg-white"
            ></div>

            <p class="text-sm uppercase tracking-[0.25em] text-zinc-500">
              {job.period}
            </p>

            <h3 class="mt-3 text-2xl font-semibold">
              {job.role}
            </h3>

            <p class="mt-1 text-zinc-400">
              {job.company}
            </p>

            <p class="mt-5 max-w-2xl leading-8 text-zinc-400">
              {job.description}
            </p>

          </div>
        ))
      }

    </div>

  </div>

</section>