---
import { portfolio } from "../data/portfolio";
---

<section class="relative overflow-hidden pt-28">

  <!-- Background Glow -->
  <div
    class="absolute left-1/2 top-20 h-[500px] w-[500px] -translate-x-1/2 rounded-full bg-indigo-500/10 blur-[180px]"
  ></div>

  <div class="container-custom relative py-24">

    <span
      class="inline-flex items-center gap-3 rounded-full border border-emerald-500/20 bg-emerald-500/10 px-4 py-2 text-sm text-emerald-400"
    >
      <span class="relative flex h-3 w-3">

        <span
          class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"
        ></span>

        <span
          class="relative inline-flex h-3 w-3 rounded-full bg-emerald-400"
        ></span>

      </span>

      {portfolio.availability}
    </span>

    <h1
      class="mt-8 max-w-5xl text-5xl font-black leading-[1.05] tracking-tight sm:text-6xl md:text-7xl xl:text-8xl"
    >
      {portfolio.hero.heading}
    </h1>

    <p
      class="mt-8 max-w-2xl text-lg leading-8 text-zinc-400 md:text-xl"
    >
      {portfolio.hero.description}
    </p>

    <div
      class="mt-12 flex flex-wrap gap-4"
    >
      <a
        href="#projects"
        class="btn-primary"
      >
        View Projects
      </a>

      <a
        href="#contact"
        class="btn-secondary"
      >
        Contact Me
      </a>
    </div>

    <a
      href={portfolio.resume}
      download
      class="group mt-10 inline-flex items-center gap-2 text-sm font-semibold uppercase tracking-[0.3em]"
    >
      <span class="border-b border-zinc-600 group-hover:border-white">
        Résumé
      </span>

      <span class="transition group-hover:translate-x-1 group-hover:-translate-y-1">
        ↗
      </span>
    </a>

    <div class="mt-20">
      <a
        href="#about"
        class="inline-flex items-center gap-3 text-sm text-zinc-500 transition hover:text-white"
      >
        <span class="animate-bounce text-lg">↓</span>

        Scroll to explore
      </a>
    </div>

  </div>

</section>