---
import { portfolio } from "../data/portfolio";
---

<section
  id="home"
  class="hero relative isolate overflow-hidden"
>

  <!-- Animated Grid -->
  <div class="hero-grid"></div>

  <!-- Noise Overlay -->
  <div class="hero-noise"></div>

  <!-- Mouse Glow -->
  <div id="hero-glow" class="hero-glow"></div>

  <!-- Gradient Orbs -->
  <div class="hero-orb hero-orb-1"></div>
  <div class="hero-orb hero-orb-2"></div>

  <div class="container-custom relative z-10 flex min-h-screen items-center py-32">

    <div class="max-w-5xl">

      <!-- Availability -->

      <div
        class="hero-item"
        data-delay="0"
      >
        <span class="availability-badge">

          <span class="availability-dot"></span>

          {portfolio.availability}

        </span>
      </div>

      <!-- Greeting -->

      <p
        class="hero-item mt-12 text-lg font-medium text-zinc-400"
        data-delay="100"
      >
        Hello, I'm
      </p>

      <!-- Name -->

      <h1
        class="hero-item mt-4 text-6xl font-black tracking-tight sm:text-7xl lg:text-8xl xl:text-9xl"
        data-delay="200"
      >
        <span class="hero-name">
          {portfolio.name}
        </span>
      </h1>

      <!-- Role -->

      <div
        class="hero-item mt-8 flex min-h-[48px] items-center"
        data-delay="300"
      >

        <span
          id="typed-role"
          class="text-2xl font-semibold text-zinc-300 md:text-4xl"
        >
          {portfolio.role}
        </span>

      </div>

      <!-- Description -->

      <p
        class="hero-item mt-10 max-w-2xl text-lg leading-9 text-zinc-400 md:text-xl"
        data-delay="400"
      >
        {portfolio.hero.description}
      </p>

      <!-- CTA Buttons -->

      <div
        class="hero-item mt-14 flex flex-wrap gap-4"
        data-delay="500"
      >

        <a
          href="#projects"
          class="btn-primary magnetic"
        >
          View Projects
        </a>

        <a
          href="#contact"
          class="btn-secondary magnetic"
        >
          Contact Me
        </a>

        <a
          href={portfolio.resume}
          download
          class="btn-secondary magnetic"
        >
          Download Résumé
        </a>

      </div>

      <!-- Social Links -->

      <div
        class="hero-item mt-16 flex flex-wrap items-center gap-8"
        data-delay="600"
      >

        <a
          href={portfolio.socials.github}
          target="_blank"
          rel="noopener noreferrer"
          class="hero-link"
        >
          GitHub
        </a>

        {
          portfolio.socials.linkedin && (
            <a
              href={portfolio.socials.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="hero-link"
            >
              LinkedIn
            </a>
          )
        }

        {
          portfolio.socials.twitter && (
            <a
              href={portfolio.socials.twitter}
              target="_blank"
              rel="noopener noreferrer"
              class="hero-link"
            >
              X
            </a>
          )
        }

        <a
          href={`mailto:${portfolio.contact.email}`}
          class="hero-link"
        >
          Email
        </a>

      </div>

    </div>

  </div>

  <!-- Scroll Indicator -->

  <a
    href="#about"
    class="hero-scroll hero-item"
    data-delay="700"
    aria-label="Scroll to About section"
  >

    <span class="mouse">

      <span class="wheel"></span>

    </span>

    <span>
      Scroll
    </span>

  </a>

</section>